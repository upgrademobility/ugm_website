{
  "name": "ugm-website",
  "description": "Website for KIT Graduate School UpGrade Mobility",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx tailwindcss -i ./css/style.css -o ./style.css --watch",
    "build": "npx tailwindcss -i ./css/style.css -o ./style.css --minify",
    "build:html": "node scripts/build-html.js",
    "optimize-images:phase1": "node scripts/optimize-images-phase1.js",
    "optimize-images:phase2": "node scripts/optimize-images-phase2.js",
    "optimize-images:phase3": "node scripts/optimize-images-phase3.js",
    "optimize-images:inner-webp": "node scripts/optimize-images-phase3.js --webp-only"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.3",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.2"
  }
}
